{
  "name": "@privy-io/wagmi",
  "version": "0.2.13",
  "description": "Wagmi bindings for the react client",
  "keywords": [
    "privy",
    "wagmi"
  ],
  "homepage": "https://docs.privy.io",
  "bugs": {
    "url": "https://privy.io/slack"
  },
  "license": "Apache-2.0",
  "author": "privy.io",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "module": "./dist/esm/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index",
  "directories": {
    "test": "test"
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "npx tsup --clean --minify",
    "check-types": "npx tsc --noEmit",
    "clean": "rm -rf dist",
    "dev": "npx tsup --watch",
    "format": "eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "generate-types": "npx tsup --dts-only",
    "lint": "npx eslint \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "jest --testMatch \"**/*(?!.*integration).test.ts\"",
    "test-integration": "jest --testMatch \"**/test/integration/**/*.test.ts\""
  },
  "browserslist": [
    "defaults",
    "node >= 18",
    "not op_mini all"
  ],
  "devDependencies": {
    "@privy-io/eslint-config-custom": "*",
    "@privy-io/react-auth": "^1.64.1",
    "@tsconfig/node16-strictest-esm": "^1.0.3",
    "@types/jest": "^29.1.2",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.0.3",
    "tsup": "^6.2.3",
    "typescript": "~5.5.3"
  },
  "peerDependencies": {
    "@privy-io/react-auth": "^1.64.1",
    "react": ">=18",
    "viem": "^2",
    "wagmi": "^2"
  },
  "publishConfig": {
    "access": "public"
  }
}
